rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isPortfolioOwner() {
      return request.auth != null
        && request.auth.token.email == 'smulherin519@gmail.com'
        && request.auth.token.email_verified == true;
    }

    function allowedAttachmentType() {
      return request.resource.contentType.matches('image/.*')
        || request.resource.contentType.matches('text/.*')
        || request.resource.contentType == 'video/mp4'
        || request.resource.contentType == 'application/pdf'
        || request.resource.contentType == 'application/msword'
        || request.resource.contentType.matches('application/vnd\\.openxmlformats-officedocument\\..*')
        || request.resource.contentType.matches('application/vnd\\.ms-.*');
    }

    match /blog/{postId}/{fileName} {
      allow read: if true;
      allow create, update: if isPortfolioOwner()
        && request.resource.size < 20 * 1024 * 1024
        && allowedAttachmentType();
      allow delete: if isPortfolioOwner();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
