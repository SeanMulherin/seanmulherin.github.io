rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isPortfolioOwner() {
      return request.auth != null
        && request.auth.token.email == 'smulherin519@gmail.com'
        && request.auth.token.email_verified == true;
    }

    function validPost() {
      return request.resource.data.keys().hasOnly([
        'title',
        'content',
        'attachments',
        'authorEmail',
        'createdAt',
        'updatedAt'
      ])
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 180
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 50000
        && request.resource.data.attachments is list
        && request.resource.data.attachments.size() <= 10
        && request.resource.data.authorEmail == 'smulherin519@gmail.com';
    }

    match /posts/{postId} {
      allow read: if true;
      allow create, update: if isPortfolioOwner() && validPost();
      allow delete: if isPortfolioOwner();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
