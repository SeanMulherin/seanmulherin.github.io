rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isPortfolioOwner() {
      return request.auth != null
        && request.auth.token.email == 'smulherin519@gmail.com'
        && request.auth.token.email_verified == true;
    }

    function validPost() {
      return request.resource.data.keys().hasOnly([
        'title',
        'content',
        'attachments',
        'authorEmail',
        'createdAt',
        'updatedAt'
      ])
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 180
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 50000
        && request.resource.data.attachments is list
        && request.resource.data.attachments.size() <= 10
        && request.resource.data.authorEmail == 'smulherin519@gmail.com';
    }

    function validSnakeScore(scoreId) {
      return request.resource.data.keys().hasOnly([
        'name',
        'nameKey',
        'score',
        'createdAt'
      ])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 24
        && request.resource.data.name.matches('^[A-Za-z0-9][A-Za-z0-9 _.-]{0,23}$')
        && request.resource.data.nameKey is string
        && request.resource.data.nameKey.size() > 0
        && request.resource.data.nameKey.size() <= 24
        && request.resource.data.nameKey.matches('^[a-z0-9][a-z0-9 _.-]{0,23}$')
        && request.resource.data.nameKey == scoreId
        && request.resource.data.score is int
        && request.resource.data.score >= 0
        && request.resource.data.score <= 5730
        && request.resource.data.createdAt == request.time;
    }

    match /posts/{postId} {
      allow read: if true;
      allow create, update: if isPortfolioOwner() && validPost();
      allow delete: if isPortfolioOwner();
    }

    match /snake_scores/{scoreId} {
      allow read: if true;
      allow create, update: if validSnakeScore(scoreId);
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
